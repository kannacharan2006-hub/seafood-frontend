# ⚠️ SECURITY NOTICE
# This .env file is for LOCAL DEVELOPMENT only.
# It is NOT bundled into the release APK (removed from assets).
#
# For production builds, pass values using --dart-define:
#   flutter build apk --release \
#     --dart-define BASE_URL=https://api.example.com \
#     --dart-define SENTRY_DSN=https://key@oX.ingest.sentry.io/Y

BASE_URL=https://seafood-backend-3.onrender.com
# Sentry DSN for crash reporting. Get yours from https://sentry.io
# Leave as-is to disable Sentry (safe for development)
SENTRY_DSN=YOUR_SENTRY_DSN_HERE
